# Public release policy only. Copy to .mac-release.env and add runtime locators there.
MAC_RELEASE_BUNDLE_ID='org.openclaw.goplaces'
MAC_RELEASE_CODESIGN_IDENTITY='Developer ID Application: OpenClaw Foundation (FWJYW4S8P8)'
MAC_RELEASE_CODESIGN_KEYCHAIN_MANAGED=1
MAC_RELEASE_CODESIGN_PASSWORDLESS=1
MAC_RELEASE_RUN_LOGIN_SHELL=0

# Configure both direct runtime locators in ignored .mac-release.env, then set
# the file mode to 0400 or 0600. The release lane rejects package-secret and
# 1Password lookup fields so release-mac-app can run with a system-only PATH.
# MAC_RELEASE_CODESIGN_KEYCHAIN='/absolute/path/to/release.keychain-db'
# export NOTARYTOOL_KEYCHAIN_PROFILE='approved-notary-profile'
